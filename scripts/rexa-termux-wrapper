#!/data/data/com.termux/files/usr/bin/sh
set -eu

REXA_HOME="/data/data/com.termux/files/home/Rexa"
DIST_ENTRY="$REXA_HOME/dist/src/index.js"
TS_ENTRY="$REXA_HOME/src/index.ts"
TSX_BIN="$REXA_HOME/node_modules/.bin/tsx"

cd "$REXA_HOME"

if [ -f "$DIST_ENTRY" ]; then
  exec node "$DIST_ENTRY" "$@"
fi

if [ -x "$TSX_BIN" ] && [ -f "$TS_ENTRY" ]; then
  exec "$TSX_BIN" "$TS_ENTRY" "$@"
fi

printf '%s\n' "Rexa belum siap dijalankan."
printf '%s\n' "Masuk ke: $REXA_HOME"
printf '%s\n' "Lalu jalankan: npm install && npm run build"
exit 1
