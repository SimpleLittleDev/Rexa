{
  "mainAgent": {
    "name": "Rexa",
    "role": "main-orchestrator",
    "provider": "codex-cli",
    "model": "gpt-5.5",
    "tools": [
      "browser",
      "terminal",
      "file",
      "memory",
      "subagent"
    ],
    "memoryScope": "global",
    "budget": {
      "maxToolCalls": 30,
      "maxExecutionTimeMs": 600000,
      "maxCostUsd": 1
    }
  },
  "subAgentPolicy": {
    "enabled": true,
    "sameProviderAsMain": true,
    "maxAgents": 3,
    "allowedTools": [
      "browser",
      "terminal",
      "file",
      "memory"
    ],
    "defaultMemoryScope": "task-only",
    "defaultBudget": {
      "maxToolCalls": 10,
      "maxExecutionTimeMs": 300000,
      "maxCostUsd": 0.5
    }
  }
}
